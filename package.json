{
  "name": "qrcode-transmitter",
  "version": "1.1.0",
  "description": "A lightweight browser library for transmitting binary data across multi-frame QR codes.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:run": "vitest run",
    "example": "vite --config example/vite.config.ts",
    "example:build": "vite build --config example/vite.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "qr-scanner": "^1.4.2",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
